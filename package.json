{
  "name": "@andrewgross/bun-decompile",
  "version": "0.1.0",
  "description": "Extracts the original transpiled sources from an executable file generated via `bun build --compile`. Supports Bun v0.6.0 through v1.4.x on macOS, Linux, and Windows.",
  "author": "Andrew Gross <andrew.w.gross@gmail.com>",
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewgross/bun-decompile-ag.git"
  },
  "bugs": {
    "url": "https://github.com/andrewgross/bun-decompile-ag/issues"
  },
  "homepage": "https://github.com/andrewgross/bun-decompile-ag#readme",
  "keywords": [
    "bun",
    "decompile",
    "unbundle",
    "extract",
    "reverse-engineering",
    "single-file-executable",
    "macho",
    "elf",
    "pe"
  ],
  "type": "module",
  "main": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "bun-decompile": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.6.2",
    "@types/bun": "^1.2.20",
    "@types/node": "^20",
    "prettier": "^3.6.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "tsc -p tsconfig.build.json",
    "release": "bun run build && npm publish",
    "start": "bun src/cli.ts",
    "test": "bun test",
    "test:e2e": "bash src/scripts/e2e-test.sh",
    "build-fixtures": "bash src/scripts/build-fixtures.sh",
    "debug-binary": "bun src/scripts/debug-binary.ts",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  }
}
